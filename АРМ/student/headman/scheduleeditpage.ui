              <property name="placeholderText"><string>напр. Контрольная по математике</string></property>
             </widget></item>
            </layout></item>

            <item><widget class="QLabel" name="eventStatusLabel">
             <property name="text"><string></string></property>
             <property name="alignment"><set>Qt::AlignCenter</set></property>
            </widget></item>

            <item><widget class="QPushButton" name="addEventButton">
             <property name="text"><string>＋ Добавить событие</string></property>
            </widget></item>

           </layout>
          </widget>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- ── Вкладка 3: Выходные ── -->
      <widget class="QWidget" name="tabHolidays">
       <attribute name="title"><string>🗓 Выходные</string></attribute>
       <layout class="QVBoxLayout">
        <item>
         <widget class="QScrollArea" name="scrollHolidays">
          <property name="widgetResizable"><bool>true</bool></property>
          <widget class="QWidget" name="scrollContents3">
