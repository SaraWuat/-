<ui version="4.0">
 <class>ScheduleEditPage</class>
 <widget class="QMainWindow" name="ScheduleEditPage">
  <property name="geometry"><rect><x>0</x><y>0</y><width>540</width><height>700</height></rect></property>
  <property name="windowTitle"><string>Расписание группы</string></property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="rootLayout">

    <item><widget class="QLabel" name="titleLabel">
     <property name="text"><string>Расписание группы</string></property>
