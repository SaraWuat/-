    <item>
     <widget class="QTabWidget" name="tabWidget">

      <!-- ── Вкладка 1: Пары ── -->
      <widget class="QWidget" name="tabClasses">
       <attribute name="title"><string>📋 Пары</string></attribute>
       <layout class="QVBoxLayout">
        <item>
         <widget class="QScrollArea" name="scrollClasses">
          <property name="widgetResizable"><bool>true</bool></property>
          <widget class="QWidget" name="scrollContents1">
           <layout class="QVBoxLayout">

            <item><widget class="QTableWidget" name="scheduleTable">
             <property name="minimumHeight"><number>160</number></property>
            </widget></item>

            <item><widget class="QLabel" name="addClassLabel">
             <property name="text"><string>Добавить пару:</string></property>
             <property name="font"><font><bold>true</bold></font></property>
            </widget></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>День:</string></property></widget></item>
             <item><widget class="QComboBox" name="weekDayCombo"/></item>
             <item><widget class="QLabel"><property name="text"><string>Неделя:</string></property></widget></item>
             <item><widget class="QComboBox" name="weekCombo"/></item>
            </layout></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>Время:</string></property></widget></item>
             <item><widget class="QComboBox" name="timeCombo"/></item>
             <item><widget class="QLabel"><property name="text"><string>Тип:</string></property></widget></item>
             <item><widget class="QComboBox" name="typeCombo">
              <item><property name="text"><string>Лекция</string></property></item>
              <item><property name="text"><string>Практика</string></property></item>
              <item><property name="text"><string>Лабораторная</string></property></item>
             </widget></item>
            </layout></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>Ауд.:</string></property></widget></item>
             <item><widget class="QLineEdit" name="placeEdit">
              <property name="placeholderText"><string>напр. 500 к. А</string></property>
             </widget></item>
            </layout></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>Предмет:</string></property></widget></item>
             <item><widget class="QComboBox" name="subjectCombo"/></item>
            </layout></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>Преподаватель:</string></property></widget></item>
             <item><widget class="QComboBox" name="teacherCombo"/></item>
            </layout></item>

            <item><widget class="QLabel" name="classStatusLabel">
             <property name="text"><string></string></property>
             <property name="alignment"><set>Qt::AlignCenter</set></property>
            </widget></item>

            <item><widget class="QPushButton" name="addClassButton">
             <property name="text"><string>＋ Добавить пару</string></property>
            </widget></item>

           </layout>
          </widget>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- ── Вкладка 2: События ── -->
      <widget class="QWidget" name="tabEvents">
       <attribute name="title"><string>📅 События</string></attribute>
       <layout class="QVBoxLayout">
        <item>
         <widget class="QScrollArea" name="scrollEvents">
          <property name="widgetResizable"><bool>true</bool></property>
          <widget class="QWidget" name="scrollContents2">
           <layout class="QVBoxLayout">

            <item><widget class="QLabel" name="eventsHint">
             <property name="text"><string>Тестирования, контрольные, мероприятия группы</string></property>
             <property name="alignment"><set>Qt::AlignCenter</set></property>
             <property name="wordWrap"><bool>true</bool></property>
            </widget></item>

            <item><widget class="QTableWidget" name="eventsTable">
             <property name="minimumHeight"><number>140</number></property>
            </widget></item>

            <item><widget class="QLabel" name="addEventLabel">
             <property name="text"><string>Добавить событие:</string></property>
             <property name="font"><font><bold>true</bold></font></property>
            </widget></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>Дата:</string></property></widget></item>
             <item><widget class="QDateEdit" name="eventDateEdit"/></item>
             <item><widget class="QLabel"><property name="text"><string>Время:</string></property></widget></item>
             <item><widget class="QLineEdit" name="eventTimeEdit">
              <property name="placeholderText"><string>08:00</string></property>
              <property name="maximumWidth"><number>70</number></property>
             </widget></item>
            </layout></item>

            <item><layout class="QHBoxLayout">
             <item><widget class="QLabel"><property name="text"><string>Название:</string></property></widget></item>
